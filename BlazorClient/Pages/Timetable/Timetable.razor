        Day = 1,
        StartBlock = 2,
        EndBlock = 4
      },
      new TimetableBlockModel()
      {
        CourseShortcut = "test shortcut 2",
        Room = "test room 2",
        Teacher = "test teacher 2",
        Day = 1,
        StartBlock = 3,
        EndBlock = 5
      },
      new TimetableBlockModel()
      {
        CourseShortcut = "test shortcut 3",
        Room = "test room 3",
        Teacher = "test teacher 3",
        Day = 1,
        StartBlock = 3,
        EndBlock = 5
      },
      new TimetableBlockModel()
      {
        CourseShortcut = "test shortcut 4",
        Room = "test room 4",
        Teacher = "test teacher 4",
        Day = 3,
